# ============================================================================
# Physical AI Robot — Backend "Robot Brain" configuration
# Copy to `.env` and adjust. All values have safe defaults in app/core/config.py.
# Env vars are UPPER_SNAKE_CASE; nested groups use "__" (e.g. MOTION__MAX_LINEAR_SPEED).
# ============================================================================

# ---- App ----
APP_NAME="Physical AI Robot Brain"
ENVIRONMENT=development            # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                     # true => JSON logs (staging/prod), false => console

# ---- API ----
API_PREFIX=/api/v1
# Comma-separated API keys for future auth (empty => auth disabled).
API_KEYS=

# ---- Database (async SQLAlchemy / asyncpg) ----
DATABASE_URL=postgresql+asyncpg://robot:robot@db:5432/robotbrain
DB_ECHO=false

# ---- Redis (hot robot state) ----
REDIS_URL=redis://redis:6379/0

# ---- AI model wiring (swap implementations without touching business logic) ----
VISION_DETECTOR=mock              # mock | yolo | rtdetr | grounding_dino
SPEECH_RECOGNIZER=mock            # mock | whisper
PLANNER=rule                      # rule | llm | rl
MEMORY_BACKEND=postgres           # postgres | chroma | qdrant
MODEL_PATH=/app/models            # directory holding model weights

# ---- Robot loop ----
ROBOT_FPS=10                      # expected control-loop frequency (informational + metrics)

# ---- Motion limits (SI units: m/s and rad/s) ----
MOTION__MAX_LINEAR_SPEED=0.6
MOTION__MAX_ANGULAR_SPEED=1.5

# ---- Follow behavior (proportional controller) ----
FOLLOW__KP_ANGULAR=1.4            # gain: horizontal offset -> angular velocity
FOLLOW__KP_LINEAR=0.8             # gain: distance error -> linear velocity
FOLLOW__TARGET_BBOX_RATIO=0.45    # desired person bbox height / frame height (distance proxy)
FOLLOW__DEADZONE=0.06             # normalized deadzone around center (no correction)

# ---- Search behavior ----
SEARCH__ANGULAR_SPEED=0.8         # in-place scan rotation speed (rad/s)

# ---- Battery guardrails (percent) ----
BATTERY__LOW_PCT=25.0
BATTERY__CRITICAL_PCT=12.0

# ---- Persistence tuning ----
PERSIST_LOGS=true
LOG_SAMPLE_N=1                    # persist 1 of every N steps to the logs table
